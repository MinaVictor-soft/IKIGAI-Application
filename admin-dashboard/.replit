entrypoint = "dist/index.html"
run = "npm run build && npm run preview"
modules = ["nodejs-20"]

[nix]
channel = "unstable"

[packager]
language = "nodejs"

[[ports]]
localPort = 4173
externalPort = 80

[userenv]

[userenv.shared]

[userenv.development]
VITE_API_URL = "/api/v1"

[userenv.production]
VITE_API_URL = "https://ikigai-backend.replit.app/api/v1"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --include=dev && npm run dev"
waitForPort = 5000

[agent]
expertMode = true

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "npm install --include=dev && npm run build"]
publicDir = "dist"
